{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["vite/client"],
    "paths": {
      "@components/*": ["./src/renderer/components/*"],
      "@hooks/*": ["./src/renderer/hooks/*"],
      "@renderer/*": ["./src/renderer/*"],
      "@screenshots/*": ["./tools/screenshots/*"],
      "@screens/*": ["./src/renderer/screens/*"],
      "@shared/*": ["./src/shared/*"],
      "@themes/*": ["./src/renderer/themes/*"]
    }
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/**/*.ts",
    "src/types/**/*.d.ts",
    "tools/screenshots/**/*.tsx",
    "tools/screenshots/fixtures.ts"
  ]
}
