{
  "name": "launchdeck",
  "version": "1.0.0",
  "description": "Secure desktop release manager for Firebase App Distribution",
  "main": "./out/main/index.js",
  "author": "LaunchDeck Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "predev": "electron-builder install-app-deps",
    "dev": "node scripts/run-electron-vite.cjs dev",
    "build": "electron-vite build",
    "prepreview": "electron-builder install-app-deps",
    "preview": "node scripts/run-electron-vite.cjs preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "node scripts/postinstall.cjs",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "bootstrap": "5.3.8",
    "plist": "5.0.0",
    "react": "19.2.7",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "@types/plist": "3.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "javascript-obfuscator": "5.4.7",
    "sass": "1.101.0",
    "typescript": "7.0.2",
    "vite": "7.3.6"
  },
  "build": {
    "appId": "com.launchdeck.app",
    "productName": "LaunchDeck",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "NSDesktopFolderUsageDescription": "LaunchDeck needs access to project files and generated release artifacts stored on your Desktop.",
        "NSDocumentsFolderUsageDescription": "LaunchDeck needs access to project files, credentials, and generated release artifacts stored in Documents.",
        "NSDownloadsFolderUsageDescription": "LaunchDeck needs access to release artifacts and project files stored in Downloads.",
        "NSNetworkVolumesUsageDescription": "LaunchDeck needs access to project files and release artifacts stored on network volumes.",
        "NSRemovableVolumesUsageDescription": "LaunchDeck needs access to project files and release artifacts stored on removable volumes."
      },
      "icon": "resources/launch-icon-macos.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/launch-icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "resources/launch-icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.6": true,
    "fsevents@2.3.3": true,
    "electron-winstaller@5.4.0": true
  }
}
